def bitstream_error_stats(bits1, bits2, verbose=True):
    """
    Compute bit mismatch statistics between two bit streams.

    Returns:
        error_rate (float) : Bit error percentage (0 → 100)
        num_errors (int)   : Number of bit mismatches
        total_bits (int)   : Total compared bits
    """

    bits1 = np.array(bits1).astype(int)
    bits2 = np.array(bits2).astype(int)

    # Length check
    if len(bits1) != len(bits2):
        min_len = min(len(bits1), len(bits2))

        #if verbose:
            #print("WARNING: Bitstreams have different lengths.")
            #print(f"Truncating to {min_len} bits for comparison.")

        bits1 = bits1[:min_len]
        bits2 = bits2[:min_len]

    # Compute errors
    diff = bits1 != bits2
    num_errors = np.sum(diff)
    total_bits = len(bits1)

    error_rate = (num_errors / total_bits) * 100 if total_bits > 0 else 0

    if verbose:
        #print("Bit Error Statistics")
        #print("-------------------")
        #print(f"Total bits   : {total_bits}")
        #print(f"Errors       : {num_errors}")
        #print(f"Error rate   : {error_rate:.4f}%")

        # Optional debugging: show mismatch positions
        mismatch_positions = np.where(diff)[0]
        #if len(mismatch_positions) > 0:
            #print("Mismatch indices (first 40):")
            #print(mismatch_positions[:40])

    return error_rate, num_errors, total_bits

def nrldpc_decode_BG111(cword, B, z, max_iter=20):

    m, n = B.shape
    L = cword.copy()
    meow = max_iter
    # Edge indexing exactly like MATLAB sequential Ri counter
    edge_list = []
    for r in range(m):
        for c in range(n):
            if B[r,c] != -1:
                edge_list.append((r,c))

    Slen = len(edge_list)
    #print(edge_list)
    R = np.zeros((Slen, z))

    Ri_global = 0

    for it in range(max_iter):
        Ri_global = 0
        for lyr in range(m):
            treg = []
            cols = []
            # subtract old R 
            Ri_local = 0
            ti = 0
            for col in np.where(B[lyr,:] != -1)[0]:
                shift = B[lyr,col]
                ti = ti + 1
                Ri_local += 1
                L[col*z:(col+1)*z] -= R[Ri_local]
                L_block = L[col*z:(col+1)*z]
                treg.append(mul_sh(L_block, shift))
                cols.append(col)
                
            treg = np.array(treg)

            # Min-Sum 
            absbuf = np.abs(treg)
            min1 = np.min(absbuf, axis=0)
            min1_pos = np.argmin(absbuf, axis=0)

            if treg.shape[0] > 1:
                part = np.partition(absbuf,1,axis=0)
                min2 = part[1]
            else:
                min2 = min1

            signs = np.sign(treg)
            signs[signs == 0] = 1
            parity = np.prod(signs, axis=0)
            ti = 0
            Ri_local -= ti
            ti = 0
            for idx in range(len(cols)):
                out_sign = parity * signs[idx]
                use_mag = np.where(min1_pos == idx, min2, min1)
                treg[idx] = out_sign * use_mag
            # column op + realign
            for idx, col in enumerate(cols):
                shift = B[lyr, col]
                R[Ri_local] = mul_sh(treg[idx], z - shift) # ciolumn alignemnet
                L[col*z:(col+1)*z] += R[Ri_local]
                Ri_local += 1
            # After finishing layer
            Ri_global = Ri_local

        hard = (L < 0).astype(int)

        if check_cword(B,z,hard) == 1:
            meow = it
            break

    return hard, L, meow

