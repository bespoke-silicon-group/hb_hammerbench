def nrldpc_decode_BG1(cword, B, z, sizeofInt, max_iter=100):
    """
    True 5G NR BG1 layered min-sum decoder.

    llr_channel : input LLR vector length = n*z
    B           : base graph matrix
    z           : lifting factor
    max_iter    : iterations
    offset      : optional offset min-sum constant
    """

    m, n = B.shape
    
    # Working LLR storage
    L = cword.copy()
    #L = quantize_fl(L, sizeofInt)
    # print(type(L))
    #offset = 0.15 * np.mean(np.abs(L))
    #print(offset)
    #print(offset.shape)
    offset = 2
    max_val = 2**(sizeofInt-1) - 1
    min_val = -2**(sizeofInt-1)
    
    edge_map = np.full(B.shape, -1, dtype=int)
    edge_counter = 0

    for r in range(m):
        for c in range(n):
            if B[r, c] != -1:
                edge_map[r, c] = edge_counter
                edge_counter += 1

    R = np.zeros((edge_counter, z), dtype=int)

    converged_iter = max_iter
    for _ in range(max_iter):
        for layer in range(m):
            cols = [c for c in range(n) if B[layer,c] != -1]
            if len(cols) == 0:
                continue
            local_msgs = []
            shifts = []
            edge_indices = []

            # Remove old R messages
            for col_idx, col in enumerate(cols):
                shift = B[layer,col]
                edge_idx = edge_map[layer,col]
                R_old_shifted = np.roll(R[edge_idx], -shift)
                # 
                # L[col*z:(col+1)*z] -= R_old_shifted
                # L[col*z:(col+1)*z] = np.clip(L[col*z:(col+1)*z], min_val, max_val)
                # L
                L_block = L[col*z:(col+1)*z] - R_old_shifted
                L_block = np.clip(L_block, min_val, max_val)
                L[col*z:(col+1)*z] = L_block
                
                local_msgs.append(np.roll(L[col*z:(col+1)*z], shift))
                
                shifts.append(shift)
                edge_indices.append(edge_idx)
            local_msgs = np.array(local_msgs)
            
            # Check node update
            absbuf = np.abs(local_msgs)
            #absbuf = 
            
            min1 = np.min(absbuf, axis=0)
            min1 = np.clip(min1, min_val, max_val)
            min1_pos = np.argmin(absbuf, axis=0)
            if len(cols) > 1:
                part = np.partition(absbuf, 1, axis=0)
                min2 = part[1]
                min2 =np.clip(min2, min_val, max_val)
            else:
                min2 = min1
                min2 = np.clip(min2, min_val, max_val)
            signs = np.sign(local_msgs)
            signs[signs == 0] = 1
            parity = np.prod(signs, axis=0)
            
            # Compute R_new first
            R_new_list = []
            for e_idx in range(len(cols)):
                out_sign = parity * signs[e_idx]
                use_mag = np.where(min1_pos == e_idx,
                    #np.maximum(min2 - offset, 0),
                    #np.maximum(min1 - offset, 0)
                    np.maximum(min2, 0),
                    np.maximum(min1, 0)
                )
                R_new_list.append(out_sign * use_mag)

            for e_idx,col in enumerate(cols):
                edge_idx = edge_indices[e_idx]
                R_new = R_new_list[e_idx]
                # R_damp = ((1 - DAMPING) * R[edge_idx] + DAMPING * R_new)
               #  R_damp = np.clip(R_damp, min_val, max_val)
                # R[edge_idx] = R_damp
                R[edge_idx] = R_new
                temp2 = L[col*z:(col+1)*z] + np.roll(R_new, -(z-shifts[e_idx]))
                # temp =  np.clip(temp2, min_val, max_val)
                L[col*z:(col+1)*z] = temp2
                
        hard = (L <= 0).astype(int)
        # hard = quantize_fl(hard, sizeofInt)

        # Syndrome check
        if (check_cword_f(B, z, hard) == 0):
            if (_ > 3 and sizeofInt < 9) or (sizeofInt >= 9):
                converged_iter = _
                #print("Converged at iteration", _)
                break

    return hard, L, converged_iter               
        
def quantize_LLR(L, sizeofInt, sigma):
    match sizeofInt:
        case 4:
            rmax = 2
        case 5:
            rmax = 3
        case 6:
            rmax = 3
        case 7:
            rmax = 5
        case 8:
            rmax = 10
        case 9:
            rmax = 20
        case default: rmax= 3
    rmax = 3.5 * sigma
    # input is LLR
    max_val = 2**(sizeofInt-1) - 1
    #rmax = 
    # sat = 4 / sigma ** 2
    # print(sat)
    # min_val = -2**(sizeofInt-1)
    # scale = max_val / sat
    # Lr = np.floor(L*scale)
    # Lc = np.clip(L, -sat, sat)
    
    # Lq = np.round(Lc * scale)
    # Lq = np.clip(Lr, min_val, max_val)
    
    Lq = np.floor(L / rmax * max_val)
    Lq = np.clip(Lq, -(max_val+1), max_val)
    
    match sizeofInt:
        case 4:
            Lq = Lq.astype(np.int8)
        case _ if 5 <= sizeofInt <= 8:
            Lq = Lq.astype(np.int8)
        case _ if 9 <= sizeofInt <= 8:
            Lq = Lq.astype(np.int16)
    return  Lq
 
def quantize_fl(num, sizeofInt):
    max_val = 2**(sizeofInt - 1) - 1
    min_val = -2**(sizeofInt - 1)

    # round first (important for float inputs)
    num_r = np.floor(num)

    # saturate
    num_sat = np.clip(num_r, min_val, max_val)
    
    match sizeofInt:
        case 4:
            num_sat = num_sat.astype(np.int8)
        case _ if 5 <= sizeofInt <= 8:
            num_sat = num_sat.astype(np.int16)
        case _ if 9 <= sizeofInt <= 16:
            num_sat = num_sat.astype(np.int16)
    return num_sat
 
