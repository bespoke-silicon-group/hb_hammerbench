def check_cword(B, z, cword):
    m, n = B.shape
    H = np.zeros((m*z, n*z), dtype=int)
    for i in range(m):
        for j in range(n):

            shift = B[i,j]

            if shift == -1:
                continue

            P = np.eye(z, dtype=int)
            P = np.roll(P, shift, axis=1)

            H[i*z:(i+1)*z,
              j*z:(j+1)*z] = P
    #print(H.shape)

    syndrome = (H @ cword.reshape(-1,1)) % 2

    # print("Syndrome weight:", np.sum(syndrome))
    if (np.any(syndrome)):
        return 0
    else:
        return 1
    
# check if code word is valid faster
def check_cword_f(B, z, c):
    # B = base matrix
    # z = edxpansion factor
    # codeword, length = expanded #columns(B)
    [m, n] = np.shape(B)
    H = np.zeros((m*z, n*z), dtype = int)
    for i in range(m):
        for j in range(n):
            shift = B[i, j]
            if shift != -1:
                I = np.eye(z, dtype=int)
                H_block = mul_sh(I, shift)
                H[i*z:(i+1)*z, j*z:(j+1)*z] = H_block
    syn = np.mod(H @ c.T, 2) # Hc^T
    # print(np.sum(syn))
    if (np.any(syn)):
        return 0
    else:
        return 1

def expand_BG_matrix(B, z):
    m, n = B.shape
    H = np.zeros((m*z, n*z), dtype=int)
    for i in range(m):
        for j in range(n):
            shift = B[i,j]
            if shift == -1:
                continue
            I = np.eye(z, dtype=int)
            H_block = np.roll(I, shift, axis=1)
            H[i*z:(i+1)*z,
              j*z:(j+1)*z] = H_block
    return H

def nrldpc_encode_BG1(B, z, msg):

    # B: base matrix
    # z: expansion factor
    # msg: message vector, length = (n-m)*z
    m, n = B.shape
    k = (n - m) * z

    if len(msg) != k:
        raise ValueError("(n-m)*z")

    cword = np.zeros(n * z, dtype=int)    
    cword[:k] = msg % 2
    # first stage
    temp = np.zeros(z, dtype=int)
    for i in range(4):
        row_temp = np.zeros(z, dtype=int)
        for j in range(n - m):
            shift = B[i, j]
            if shift == -1:
                continue

            block = msg[j*z:(j+1)*z]
            temp = (temp + mul_sh(block, shift)) % 2
    if B[1, n-m] == -1:
        p1_sh = B[2, n-m]
    else:
        p1_sh = B[1, n-m]
    cword[(n-m)*z:(n-m+1)*z] = mul_sh(temp, z - p1_sh)
        
    # second stage
    for i in range(3):
        temp = np.zeros(z, dtype=int)
        for j in range(n - m + i+1):
            shift = B[i, j]

            if shift == -1:
                continue

            block = cword[j*z:(j+1)*z]
            temp = (temp + mul_sh(block, shift)) % 2

        cword[(n - m + i) * z : (n - m + i + 1) * z] = temp
    # third
    for i in range(4, m):

        temp = np.zeros(z, dtype=int)

        for j in range(n - m + 4):
            shift = B[i, j]

            if shift == -1:
                continue

            block = cword[j*z:(j+1)*z]
            temp = (temp + mul_sh(block, shift)) % 2

    cword[(n - m + i - 1) * z : (n - m + i) * z] = temp
    return cword

